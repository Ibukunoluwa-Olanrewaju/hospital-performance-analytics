    <worksheet name='Diagnosis readmit'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>One in Three Lung Cell Carcinoma Patients Are Readmitted Post-Discharge</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Zion Tech Capstone' name='federated.1pkmirb1409dpk1alarye0vm1qvv' />
          </datasources>
          <datasource-dependencies datasource='federated.1pkmirb1409dpk1alarye0vm1qvv'>
            <column caption='Readmission Rate, from the v_flagged_readmission Table' datatype='real' name='[Calculation_1252627628490790]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([is_readmission]) * 100 / COUNTD ([encounter_id (v_flagged_readmissions)])' />
            </column>
            <column-instance column='[encounter_id (v_flagged_readmissions)]' derivation='Count' name='[cnt:encounter_id (v_flagged_readmissions):qk]' pivot='key' type='quantitative' />
            <column caption='Diagnosis (V Flagged Readmissions)' datatype='string' name='[diagnosis (v_flagged_readmissions)]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Chronic congestive heart failure (disorder)&quot;' value='Chronic Heart Failure' />
                <alias key='&quot;History of aortic valve replacement (situation)&quot;' value='History of Aortic Valve Replacement' />
                <alias key='&quot;History of coronary artery bypass grafting (situation)&quot;' value='History of CABG' />
                <alias key='&quot;Non-small cell carcinoma of lung  TNM stage 1 (disorder)&quot;' value='Lung Cell Carcinoma' />
              </aliases>
            </column>
            <column caption='Encounter Id (V Flagged Readmissions)' datatype='string' default-role='measure' default-type='quantitative' name='[encounter_id (v_flagged_readmissions)]' role='dimension' type='nominal' />
            <column caption='Is Readmission' datatype='integer' name='[is_readmission]' role='measure' type='quantitative' />
            <column-instance column='[diagnosis (v_flagged_readmissions)]' derivation='None' name='[none:diagnosis (v_flagged_readmissions):nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1252627628490790]' derivation='User' name='[usr:Calculation_1252627628490790:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.1pkmirb1409dpk1alarye0vm1qvv].[cnt:encounter_id (v_flagged_readmissions):qk]' included-values='in-range'>
            <min>70</min>
          </filter>
          <filter class='categorical' column='[federated.1pkmirb1409dpk1alarye0vm1qvv].[none:diagnosis (v_flagged_readmissions):nk]' context='true'>
            <groupfilter function='except' user:ui-domain='relevant' user:ui-enumeration='exclusive' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[none:diagnosis (v_flagged_readmissions):nk]' />
              <groupfilter function='union'>
                <groupfilter function='member' level='[none:diagnosis (v_flagged_readmissions):nk]' member='&quot;Dependent drug abuse (disorder)&quot;' />
                <groupfilter function='member' level='[none:diagnosis (v_flagged_readmissions):nk]' member='&quot;Sterilization requested (situation)&quot;' />
              </groupfilter>
            </groupfilter>
          </filter>
