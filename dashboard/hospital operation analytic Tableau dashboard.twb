    <dashboard enable-sort-zone-taborder='true' name='Dashboard 7'>
      <style />
      <size maxheight='800' maxwidth='1500' minheight='800' minwidth='1500' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='3' param='vert' type-v2='layout-flow' w='98934' x='533' y='1000'>
            <zone fixed-size='744' forceUpdate='true' h='94000' id='5' is-fixed='true' type-v2='text' w='98934' x='533' y='1000'>
              <formatted-text>
                <run fontalignment='1' fontcolor='#000000' fontname='Tableau Semibold' fontsize='18'>     Data Structure &amp; Analytical Approach</run>
                <run fontalignment='1'>Æ&#10;</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>The analysis utilized approximately </run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>1 million records</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> covering inpatient encounters, patient demographics, diagnoses, procedures, payer information, and financial transactions.</run>
                <run>Æ&#10;&#10;</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Data from multiple relational tables (</run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>encounter, patient, procedures, financial, and payers table</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>) were integrated using:</run>
                <run>Æ&#10;&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Encounter ID</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Patient ID</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Payer ID</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'> To create a unified analytical dataset.</run>
                <run>Æ&#10;&#10;</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Key metrics developed to assess patient flow, operational efficiency, and financial performance:</run>
                <run>Æ&#10;&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Inpatient Volume</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>ALOS</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Total Bed Day Burden</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Readmission Rate</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>• </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Net Revenue</run>
                <run>Æ&#10;&#10;</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Data preparation was completed in </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Excel</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>, analytical modeling in </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>PostgreSQL</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>, and visualization in </run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>Tableau</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>.</run>
                <run>Æ&#10;&#10;</run>
                <run fontcolor='#000000' fontname='Tableau Semibold' fontsize='12'>The analysis focused on identifying factors contributing to patient flow challenges, capacity pressures, readmissions, and financial sustainability.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
                <format attr='background-color' value='#f3f4f6' />
              </zone-style>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
