          </shelf-sorts>
          <slices>
            <column>[federated.1pkmirb1409dpk1alarye0vm1qvv].[none:diagnosis (v_flagged_readmissions):nk]</column>
            <column>[federated.1pkmirb1409dpk1alarye0vm1qvv].[cnt:encounter_id (v_flagged_readmissions):qk]</column>
          </slices>
